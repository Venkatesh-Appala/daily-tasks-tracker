# JSONBin cross-device sync credentials.
# Copy this file to `.env` for local dev, and set the same vars in the Vercel
# project (Settings -> Environment Variables) for the deployed app.
#
# NOTE: in the local `.env` file each `$` in the access key must be escaped as `\$`
# (otherwise Vite's dotenv expansion eats it). In the Vercel dashboard paste the
# key RAW (no backslashes) — Vercel does not expand env values.

VITE_JSONBIN_BIN_ID=your-bin-id
VITE_JSONBIN_ACCESS_KEY=your-access-key
